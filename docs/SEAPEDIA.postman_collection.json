{
  "info": {
    "name": "SEAPEDIA API",
    "description": "SEAPEDIA multi-role marketplace API. Set {{baseUrl}} (default http://localhost:3000/api/v1). Auth uses an httpOnly session cookie: run Auth > login first and Postman keeps the cookie for subsequent requests. For multi-role users, call POST /auth/active-role after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register — Register a new account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"budisantoso\",\n  \"name\": \"Budi Santoso\",\n  \"email\": \"budi@mail.com\",\n  \"phone\": \"081234567890\",\n  \"password\": \"seapedia123\",\n  \"roles\": [\n    \"BUYER\",\n    \"SELLER\"\n  ]\n}",
              "options": {
                "raw": {
